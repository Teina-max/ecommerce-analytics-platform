# Supabase (auto-injected in Edge Functions)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Hiboutik POS API - Primary (4 stores)
HIBOUTIK_PRIMARY_API_URL=https://your-store.hiboutik.com/api
HIBOUTIK_PRIMARY_API_USER=your-email@example.com
HIBOUTIK_PRIMARY_API_KEY=your-api-key

# Hiboutik POS API - Secondary (2 stores)
HIBOUTIK_SECONDARY_API_URL=https://your-store-2.hiboutik.com/api
HIBOUTIK_SECONDARY_API_USER=your-email@example.com
HIBOUTIK_SECONDARY_API_KEY=your-api-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
TELEGRAM_NOTIFY_CHAT_IDS=chat-id-1,chat-id-2
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
